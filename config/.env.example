# Copy to config/.env and adjust. Loads from config/.env (and optionally repo-root .env).
# Git ignores secrets; this file is safe to commit.

# --- AWS (Bedrock) ---
# Region for Bedrock Converse. Use a region where your models are enabled.
AWS_REGION=ap-south-1

# Optional: Bedrock API key (some setups). If unset, boto3 uses the default credential chain
# (e.g. AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY, SSO, EC2/ECS instance role).
# AWS_BEDROCK_API_KEY=

# --- Proxy authentication (callers of /api/v1/*) ---
# If set OR if you created keys via /api/v1/admin/keys, clients must send:
#   X-API-Key: <value>   or   Authorization: Bearer <value>
# If unset AND no admin-created keys exist, the proxy accepts unauthenticated requests (dev only).
# BEDROCK_ENDPOINT_API_KEY=your-long-random-secret

# --- Admin API (/api/v1/admin/*) ---
# Required to create/list/revoke sk- keys and read usage. Send as:
#   X-Admin-Key: <value>   or   Authorization: Bearer <value>
# ADMIN_API_KEY=another-long-random-secret

# --- Server (local dev; production often uses systemd/nginx on 127.0.0.1:8000) ---
# SERVER_HOST=0.0.0.0
# SERVER_PORT=4000
# SERVER_WORKERS=1
# DEBUG=false
# LOGGING_LEVEL=info
